          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/trackingdetail/orders?email={{testEmail}}&limit=10",
              "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","orders"],
              "query": [{ "key": "email", "value": "{{testEmail}}" }, { "key": "limit", "value": "10" }]
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "  pm.test('Has email + orders array', () => {",
            "    const j = pm.response.json();",
            "    pm.expect(j).to.have.property('email');",
            "    pm.expect(j.orders).to.be.an('array');",
            "  });",
            "} else {",
            "  pm.test('No authToken yet — expected 401', () => {",
            "    pm.expect(pm.response.code).to.equal(401);",
            "    pm.expect(pm.response.json()).to.have.property('error');",
            "  });",
            "}"
          ]}}]
        },

        {
          "name": "Get My Orders (body)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"limit\": 10}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/trackingdetail/orders", "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","orders"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "  pm.test('Has email + orders array', () => {",
            "    const j = pm.response.json();",
            "    pm.expect(j).to.have.property('email');",
            "    pm.expect(j.orders).to.be.an('array');",
            "  });",
            "} else {",
            "  pm.test('No authToken yet — expected 401', () => {",
            "    pm.expect(pm.response.code).to.equal(401);",
            "    pm.expect(pm.response.json()).to.have.property('error');",
            "  });",
            "}"
          ]}}]
        }

      ]
    },

