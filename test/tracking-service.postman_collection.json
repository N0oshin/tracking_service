{
  "info": {
    "name": "Tracking Service API Tests",
    "_postman_id": "b2c3d4e5-f6a7-4890-bcde-f12345678901",
    "description": "Full API test suite for tracking-service. Run with the matching environment file.\n\nIMPORTANT — this service uses email OTP auth, not username/password, so it cannot be 100% automated end-to-end without a manual step:\n1. Run 'OTP Auth Flow > Request OTP' — this emails a 6-digit code to {{testEmail}} (must be an email that already has at least one order).\n2. Open the email (or check the Resend/Mailjet dashboard, or server logs if RESEND_API_KEY isn't configured), copy the code, and paste it into the collection variable 'otpCode'.\n3. Run 'OTP Auth Flow > Verify OTP' — this captures 'authToken' automatically for every Bearer-protected request below.\n\nAll other folders can be run via Collection Runner without manual steps EXCEPT the ones needing 'authToken': those requests are written to tolerate a 401 gracefully (they check response shape rather than hard-failing) so a full run without step 2 still passes, just without exercising the authenticated behavior.\n\nA 'Server-to-Server (x-api-key)' folder is included for fully automated runs: set environment variable 'apiKey' to match the service's TRACKING_API_KEY (if configured) to bypass the OTP requirement entirely on protected routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",                       "value": "http://localhost:5002" },
    { "key": "authToken",                     "value": "" },
    { "key": "otpCode",                       "value": "" },
    { "key": "testOrderNumber",               "value": "" },
    { "key": "testOrderId",                   "value": "" },
    { "key": "createdAddressChangeRequestId", "value": "" }
  ],
  "item": [

    {
      "name": "Health",
      "item": [

        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Reports connected DB', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.ok).to.be.true;",
            "  pm.expect(j).to.have.property('service', 'tracking-service');",
            "  pm.expect(j).to.have.property('db', 'connected');",
            "});"
          ]}}]
        }

      ]
    },

    {
      "name": "OTP Auth Flow",
      "item": [

        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/trackingdetail/request-otp", "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","request-otp"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Response is ok (never reveals whether the email exists)', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.ok).to.be.true;",
            "});",
            "console.log('If testEmail has an order, a 6-digit OTP was just emailed. Paste it into the otpCode collection variable, then run Verify OTP.');"
          ]}}]
        },

        {
          "name": "Request OTP - Missing Email → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/trackingdetail/request-otp", "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","request-otp"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('Error message present', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.ok).to.be.false;",
            "  pm.expect(j).to.have.property('error', 'Valid email is required');",
            "});"
          ]}}]
        },

        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"otp\": \"{{otpCode}}\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/trackingdetail/verify-otp", "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","verify-otp"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Response is JSON', () => pm.response.to.be.json);",
            "if (pm.response.code === 200) {",
            "  const j = pm.response.json();",
            "  pm.test('Has token and expiresIn', () => {",
            "    pm.expect(j.ok).to.be.true;",
            "    pm.expect(j).to.have.property('token');",
            "    pm.expect(j).to.have.property('expiresIn');",
            "  });",
            "  pm.collectionVariables.set('authToken', j.token);",
            "  console.log('authToken captured — Bearer-protected requests below will now run authenticated.');",
            "} else {",
            "  pm.test('otpCode not set yet — expected 400 (\"Valid 6-digit OTP is required\" or \"Invalid OTP\")', () => {",
            "    pm.expect(pm.response.code).to.equal(400);",
            "    pm.expect(pm.response.json()).to.have.property('error');",
            "  });",
            "  console.log('Set the otpCode collection variable to the code emailed to testEmail, then re-run this request.');",
            "}"
          ]}}]
        },

        {
          "name": "Verify OTP - Invalid Code → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"otp\": \"000000\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/trackingdetail/verify-otp", "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","verify-otp"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('Error message present', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.ok).to.be.false;",
            "  pm.expect(j).to.have.property('error');",
            "});"
          ]}}]
        },

        {
          "name": "Verify OTP - Missing Fields → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/trackingdetail/verify-otp", "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","verify-otp"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('Error message present', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.ok).to.be.false;",
            "  pm.expect(j).to.have.property('error', 'Valid email is required');",
            "});"
          ]}}]
        }

      ]
    },

    {
      "name": "Orders — Public (No Auth)",
      "item": [

        {
          "name": "Orders By Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"limit\": 10}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/trackingdetail/orders-by-email", "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","orders-by-email"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has ok + orders array', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.ok).to.be.true;",
            "  pm.expect(j.orders).to.be.an('array');",
            "});",
            "const j = pm.response.json();",
            "if (Array.isArray(j.orders) && j.orders.length > 0) {",
            "  const first = j.orders[0];",
            "  pm.test('Each entry has order/items/payments', () => {",
            "    pm.expect(first).to.have.all.keys('order', 'items', 'payments');",
            "  });",
            "  pm.collectionVariables.set('testOrderNumber', first.order.order_number);",
            "  pm.collectionVariables.set('testOrderId', String(first.order.id));",
            "  console.log('testOrderNumber/testOrderId captured for downstream requests:', first.order.order_number);",
            "} else {",
            "  console.warn('testEmail has no orders — set environment variable testEmail to an email with at least one order for full coverage.');",
            "}"
          ]}}]
        },

        {
          "name": "Orders By Email - Missing Email → 400",
          "request": {
