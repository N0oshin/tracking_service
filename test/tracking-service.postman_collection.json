            "    const j = pm.response.json();",
            "    pm.expect(j).to.have.property('ok');",
            "  });",
            "}"
          ]}}]
        }

      ]
    },

    {
      "name": "Address Change Requests (Bearer)",
      "item": [

        {
          "name": "List Address Change Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/trackingdetail/address-change-requests?email={{testEmail}}",
              "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","address-change-requests"],
              "query": [{ "key": "email", "value": "{{testEmail}}" }]
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "  pm.test('Has requests array', () => {",
            "    const j = pm.response.json();",
            "    pm.expect(j.requests).to.be.an('array');",
            "  });",
            "} else {",
            "  pm.test('No authToken yet — expected 401', () => pm.expect(pm.response.code).to.equal(401));",
            "}"
          ]}}]
        },

        {
          "name": "Create Address Change Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"shipping_address\": \"99 Postman Test Street\", \"shipping_city\": \"Manchester\", \"shipping_zip\": \"M1 1AA\", \"shipping_country\": \"United Kingdom\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/trackingdetail/order/{{testOrderNumber}}/address-change-request", "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","order","{{testOrderNumber}}","address-change-request"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "// Accepts 200 (created) or 409 (a prior run already left one pending) as both being",
            "// correct behaviour — this endpoint intentionally refuses a second pending request.",
            "if (pm.response.code === 200) {",
            "  pm.test('Created with an id', () => {",
            "    const j = pm.response.json();",
            "    pm.expect(j.success).to.be.true;",
            "    pm.expect(j).to.have.property('id');",
            "    pm.collectionVariables.set('createdAddressChangeRequestId', String(j.id));",
            "  });",
            "} else if (pm.response.code === 409) {",
            "  pm.test('Already-pending conflict reported correctly', () => {",
            "    pm.expect(pm.response.json()).to.have.property('error');",
            "  });",
            "} else if (pm.response.code === 401) {",
            "  pm.test('No authToken yet — expected 401', () => pm.expect(pm.response.json()).to.have.property('error'));",
            "} else {",
            "  pm.test('Unexpected status', () => pm.expect.fail('Expected 200, 409, or 401 but got ' + pm.response.code));",
            "}"
          ]}}]
        },

        {
          "name": "Create Address Change Request (Duplicate) → 409",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{testEmail}}\", \"shipping_address\": \"another address\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/trackingdetail/order/{{testOrderNumber}}/address-change-request", "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","order","{{testOrderNumber}}","address-change-request"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 401) {",
            "  pm.test('No authToken yet — expected 401', () => pm.expect(pm.response.json()).to.have.property('error'));",
            "} else {",
            "  pm.test('Status 409 (pending request already exists)', () => pm.response.to.have.status(409));",
            "  pm.test('Error message present', () => pm.expect(pm.response.json()).to.have.property('error'));",
            "}"
          ]}}]
        },

        {
          "name": "Create Address Change Request - Missing shipping_address → 400",
