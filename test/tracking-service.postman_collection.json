    {
      "name": "Error Handling",
      "item": [

        {
          "name": "Missing Auth → 401",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/trackingdetail/orders?email={{testEmail}}",
              "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","orders"],
              "query": [{ "key": "email", "value": "{{testEmail}}" }]
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "pm.test('Error is \"OTP verification required\"', () => {",
            "  pm.expect(pm.response.json()).to.have.property('error', 'OTP verification required');",
            "});"
          ]}}]
        },

        {
          "name": "Invalid Bearer Token → 401",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer this.is.not.a.valid.jwt" }],
            "url": {
              "raw": "{{baseUrl}}/api/trackingdetail/orders?email={{testEmail}}",
              "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","orders"],
              "query": [{ "key": "email", "value": "{{testEmail}}" }]
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "pm.test('Error is \"Invalid or expired access token\"', () => {",
            "  pm.expect(pm.response.json()).to.have.property('error', 'Invalid or expired access token');",
            "});"
          ]}}]
        },

        {
          "name": "Verify OTP With No Prior Request → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"no-otp-ever-requested-for-this-address@example.com\", \"otp\": \"123456\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/trackingdetail/verify-otp", "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","verify-otp"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('Error is \"Invalid OTP\"', () => {",
            "  pm.expect(pm.response.json()).to.have.property('error', 'Invalid OTP');",
            "});"
          ]}}]
        },

        {
          "name": "Health Check Never Requires Auth",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer garbage" }],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200 regardless of bad Authorization header', () => pm.response.to.have.status(200));"
          ]}}]
        }

      ]
    }

  ]
