            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/trackingdetail/tracking/TEST123456789GB", "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","tracking","TEST123456789GB"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "// As shipped, TRACKING_EVENTS_API_BASE_URL is unconfigured, so an authenticated call",
