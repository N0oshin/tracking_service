              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/trackingdetail/orders-by-email", "host": ["{{baseUrl}}"], "path": ["api","trackingdetail","orders-by-email"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('Error message present', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.ok).to.be.false;",
            "  pm.expect(j).to.have.property('error', 'Valid email is required');",
            "});"
          ]}}]
        }

