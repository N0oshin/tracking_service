# =============================================================================
# tracking-service — environment configuration
# Copy this file to `.env` and fill in real values.
# =============================================================================

# ---- Service ----
TRACKING_SERVICE_PORT=5002

# CORS: "*" allows ANY website to call this microservice (default).
# To restrict, set a comma-separated list of allowed origins instead, e.g.:
#   CORS_ORIGIN=https://alluvi.com,https://app.alluvi.com
CORS_ORIGIN=*

# ---- Database (Supabase PostgreSQL) ----
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.aygbtulwwpwsujiomgtm
DB_PASS=YOUR-DATABASE-PASSWORD
DB_NAME=postgres

# ---- Auth ----
TRACKING_JWT_SECRET=

# Optional: if set, requests bearing header `x-api-key: <this value>` bypass
# the OTP/bearer-token check on protected routes (trusted server-to-server use).
TRACKING_API_KEY=

TRACKING_OTP_TTL_SECONDS=600
TRACKING_OTP_MAX_ATTEMPTS=5
TRACKING_ACCESS_TOKEN_TTL_SECONDS=900

# ---- Email (OTP delivery) ----
RESEND_API_KEY=
EMAIL_FROM_EMAIL=info@alluvi.org
EMAIL_FROM_NAME=Team Alluvi

# ---- External tracking-events provider (optional) ----
TRACKING_EVENTS_API_BASE_URL=
TRACKING_EVENTS_API_KEY=
TRACKING_EVENTS_DEFAULT_CARRIER=royalmail
